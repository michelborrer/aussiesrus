---
import Article from '../../../layouts/Article.astro';
import Fig from '../../../components/Fig.astro';
import Callout from '../../../components/Callout.astro';
import DataTable from '../../../components/DataTable.astro';
import FaqBlock from '../../../components/FaqBlock.astro';
import CtaButton from '../../../components/CtaButton.astro';
import { getRebates, getSystems } from '../../../lib/data';
import {
  calculateFederalRebate,
  dollarsPerUsableKwh,
  formatAud,
  formatDateLong,
} from '../../../lib/rebate';

const rebates = getRebates();
const systems = getSystems().systems;
const sys = systems.find((s) => s.id === '10kwh')!;
const fed = calculateFederalRebate(sys.usableKwh, rebates);
const net = sys.typicalInstalledCost - fed.federalRebate;
const perKwh = dollarsPerUsableKwh(rebates);
const perKwhNet = net / sys.usableKwh;

const compareRows = systems.map((s) => {
  const f = calculateFederalRebate(s.usableKwh, rebates);
  const n = s.typicalInstalledCost - f.federalRebate;
  return [
    s.label,
    formatAud(s.typicalInstalledCost),
    formatAud(f.federalRebate),
    formatAud(n),
    formatAud(n / s.usableKwh),
  ];
});

const faq = [
  {
    question: 'Is $9,000 a guaranteed price?',
    answer:
      'No. It is our reference typical installed cost for planning. Site access, inverter pairing, electrical upgrades and brand choice move real quotes.',
  },
  {
    question: 'Does a 10 kWh battery get the full federal tier?',
    answer:
      'Yes for usable capacity — 10 kWh sits inside the 0–14 kWh band that receives 100% of the current STC factor under the May 2026 rules.',
  },
  {
    question: 'Should I go bigger for more rebate?',
    answer:
      'Not automatically. Beyond 14 kWh usable, federal support per extra kWh falls. Size to evening load first.',
  },
];

const description = `Typical 10 kWh home battery cost in Australia after the federal rebate. Reference installed ${formatAud(sys.typicalInstalledCost)}, federal support about ${formatAud(fed.federalRebate)}.`;
---

<Article
  title="10 kWh battery cost after the federal rebate"
  description={description}
  crumbs={[
    { label: 'Home', href: '/' },
    { label: 'Costs', href: '/costs/10kwh-battery-cost/' },
    { label: '10 kWh battery' },
  ]}
  updated="2026-07-12"
  verified={rebates.meta.lastVerified}
>
  <Fragment slot="toc">
    <ul>
      <li><a href="#price">Typical price</a></li>
      <li><a href="#rebate">Rebate and net</a></li>
      <li><a href="#compare">Compare sizes</a></li>
      <li><a href="#drivers">What moves quotes</a></li>
      <li><a href="#sources">Sources</a></li>
    </ul>
  </Fragment>

  <p>
    A <Fig>10</Fig> kWh usable home battery is the smallest of our three reference systems — enough for
    many households to cover a solid block of evening load without crossing into discounted federal rebate
    tiers. At current rates, tier-1 support is about <Fig>{formatAud(perKwh)}</Fig> per usable kWh
    (verified {formatDateLong(rebates.meta.lastVerified)}).
  </p>

  <h2 id="price">Typical installed price</h2>
  <p>
    Our planning figure for a turnkey <Fig>10</Fig> kWh battery is{' '} <Fig>{formatAud(sys.typicalInstalledCost)}</Fig> before rebates. That assumes a straightforward
    retrofit beside existing solar, not a switchboard rebuild or three-phase special case.
  </p>

  <h2 id="rebate">Federal rebate and net cost</h2>
  <DataTable
    headers={['Line', 'Amount']}
    rows={[
      ['Typical installed (reference)', formatAud(sys.typicalInstalledCost)],
      ['Federal rebate', formatAud(fed.federalRebate)],
      ['Illustrative net', formatAud(net)],
      ['Net per usable kWh', formatAud(perKwhNet)],
    ]}
    numericCols={[1]}
  />
  <p>
    Federal support of <Fig>{formatAud(fed.federalRebate)}</Fig> ( <Fig>{fed.stcCount}</Fig> STCs) brings the illustrative net to <Fig>{formatAud(net)}</Fig>. Add any
    state scheme on your <a href="/battery-rebate/wa/">state stacking page</a>.
  </p>

  <h2 id="compare">Price per kWh versus other sizes</h2>
  <DataTable
    caption="Reference systems after federal rebate only"
    headers={['System', 'Typical installed', 'Federal rebate', 'Net', 'Net $/usable kWh']}
    rows={compareRows}
    numericCols={[1, 2, 3, 4]}
  />

  <h2 id="drivers">What drives quotes up or down</h2>
  <ul>
    <li>Hybrid versus AC-coupled architecture and inverter brand</li>
    <li>Switchboard, metering, and cabling upgrades</li>
    <li>Multi-storey or restricted access installs</li>
    <li>Warranty length and round-trip efficiency</li>
    <li>Whether electrical works are bundled with new panels</li>
  </ul>
  <Callout type="note" title="No installer picks in v1">
    <p>We publish cost bands and rebate maths — not a recommended installer list.</p>
  </Callout>

  <p>
    <CtaButton href="/battery-rebate/calculator/">Calculate my rebate</CtaButton>
  </p>

  <h2 id="sources">Sources</h2>
  <ul>
    <li> <a href={rebates.meta.sourceUrl}>{rebates.meta.program}</a>
    </li>
    <li> <a href="/guides/is-a-battery-worth-it/">Is a battery worth it?</a>
    </li>
  </ul>

  <FaqBlock items={faq} />
</Article>
