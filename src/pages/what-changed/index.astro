---
import Article from '../../layouts/Article.astro';
import { getChangelog, getRebates } from '../../lib/data';
import { formatDateLong } from '../../lib/rebate';

const rebates = getRebates();
const changelog = getChangelog();
const entries = changelog.entries;
const programHistory = changelog.programHistory ?? [];

const description =
  'Changelog of verified rebate, FiT and cost data updates on Aussies R Us — every material change, dated, with affected pages.';
---

<Article
  title="What changed"
  description={description}
  crumbs={[{ label: 'Home', href: '/' }, { label: 'What changed' }]}
  updated="2026-07-12"
  verified={rebates.meta.lastVerified}
>
  <Fragment slot="toc">
    <ul>
      <li><a href="#verification-log">Verification log</a></li>
      {programHistory.length > 0 && (
        <li>
          <a href="#program-history">Program history</a>
        </li>
      )}
    </ul>
  </Fragment>

  <p>
    Every time we change a data file that drives rates, schemes, FiTs or reference costs, we record it
    here. This page is the public audit trail behind the verified stamps you see on articles. Subscribe
    via <a href="/rss.xml">RSS</a>.
  </p>

  <h2 id="verification-log">Verification log</h2>
  <p class="section-lead">
    Site activity only — checks and data updates we actually performed on Aussies R Us.
  </p>

  <ol class="changelog">
    {
      entries.map((entry) => (
        <li id={`e-${entry.date}`}>
          <h3>
            <time datetime={entry.date}>{formatDateLong(entry.date)}</time>
          </h3>
          <p>{entry.summary}</p>
          {entry.affectedPages.length > 0 && (
            <p class="affected">
              Affected:{' '}
              {entry.affectedPages.map((path, i) => (
                <>
                  {i > 0 && ', '}
                  <a href={path.endsWith('/') || path === '/' ? path : `${path}/`}>{path}</a>
                </>
              ))}
            </p>
          )}
        </li>
      ))
    }
  </ol>

  {
    programHistory.length > 0 && (
      <section class="program-history" aria-labelledby="program-history">
        <h2 id="program-history">Program history</h2>
        <p class="section-lead">
          Background context on the federal program and related industry events. These entries predate
          this site and are not verification activity.
        </p>
        <ol class="changelog changelog--history">
          {programHistory.map((entry) => (
            <li id={`h-${entry.date}`}>
              <h3>
                <time datetime={entry.date}>{formatDateLong(entry.date)}</time>
              </h3>
              <p>{entry.summary}</p>
            </li>
          ))}
        </ol>
      </section>
    )
  }
</Article>

<style>
  .section-lead {
    color: var(--ink-soft);
    font-size: var(--t-meta);
    margin-top: calc(var(--s-2) * -1);
  }

  .changelog {
    list-style: none;
    padding: 0;
    margin: var(--s-6) 0 0;
  }

  .changelog > li {
    padding: var(--s-5) 0;
    border-top: 1px solid var(--line);
  }

  .changelog h3 {
    font-size: var(--t-h3);
    font-family: var(--font-body);
    font-weight: 600;
    margin-bottom: var(--s-3);
  }

  .affected {
    font-size: var(--t-meta);
    color: var(--ink-soft);
  }

  .program-history {
    margin-top: var(--s-8);
    padding: var(--s-6);
    background: var(--paper-dim);
    border: 1px solid var(--line);
    border-radius: var(--r-m);
  }

  .program-history .changelog {
    margin-top: var(--s-5);
  }

  .changelog--history > li:first-child {
    border-top: none;
    padding-top: 0;
  }
</style>
