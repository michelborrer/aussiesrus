---
import { NAV, SITE } from '../lib/site';

const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
}
---

<header class="site-header">
  <div class="wrap header-inner">
    <a class="wordmark" href="/" aria-label={`${SITE.name} home`}>
      <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true">
        <rect width="36" height="36" rx="8" fill="var(--sun)"></rect>
        <text
          x="18"
          y="24"
          text-anchor="middle"
          font-family="Archivo, sans-serif"
          font-weight="800"
          font-size="18"
          fill="var(--ink)">R</text
        >
      </svg>
      <span class="wordmark-text">Aussies R Us</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <ul class="nav-list">
        {
          NAV.map((item) => (
            <li class:list={['nav-item', { 'has-children': 'children' in item && item.children }]}>
              {'children' in item && item.children ? (
                <>
                  <a
                    class:list={['nav-link', { active: isActive(item.href) }]}
                    href={item.href}
                    aria-haspopup="true"
                  >
                    {item.label}
                    <span class="caret" aria-hidden="true">▾</span>
                  </a>
                  <ul class="dropdown">
                    {item.children.map((child) => (
                      <li>
                        <a
                          class:list={['dropdown-link', { active: path === child.href }]}
                          href={child.href}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </>
              ) : (
                <a class:list={['nav-link', { active: isActive(item.href) }]} href={item.href}>
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    min-height: 72px;
    padding-block: var(--s-3);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    text-decoration: none;
    color: var(--ink);
    flex-shrink: 0;
  }

  .wordmark-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-stretch: semi-expanded;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-1);
    list-style: none;
    margin: 0;
    padding: 0;
    justify-content: flex-end;
  }

  .nav-item {
    position: relative;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--s-1);
    min-height: 44px;
    padding: var(--s-2) var(--s-3);
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--t-meta);
    border-bottom: 2px solid transparent;
  }

  .nav-link.active,
  .nav-link:hover {
    border-bottom-color: var(--sun);
  }

  .caret {
    font-size: 0.7em;
    opacity: 0.7;
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 240px;
    margin: 0;
    padding: var(--s-2);
    list-style: none;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-s);
    z-index: 50;
  }

  .nav-item:hover .dropdown,
  .nav-item:focus-within .dropdown {
    display: block;
  }

  .dropdown-link {
    display: block;
    padding: var(--s-3);
    min-height: 44px;
    color: var(--ink);
    text-decoration: none;
    border-radius: var(--r-s);
    font-size: var(--t-meta);
  }

  .dropdown-link:hover,
  .dropdown-link.active {
    background: var(--paper-dim);
    color: var(--eucalypt);
  }

  @media (max-width: 820px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .nav {
      width: 100%;
      overflow-x: auto;
    }

    .nav-list {
      justify-content: flex-start;
      flex-wrap: nowrap;
    }

    .dropdown {
      position: static;
      border: none;
      padding: 0 0 0 var(--s-3);
      display: none;
    }

    .nav-item:hover .dropdown,
    .nav-item:focus-within .dropdown {
      display: block;
    }
  }
</style>
