---
import { NAV, SITE } from '../lib/site';

const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return path === '/';
  return path === href || path.startsWith(href);
}
---

<header class="site-header">
  <div class="wrap header-inner">
    <a class="wordmark" href="/" aria-label={`${SITE.name} home`}>
      <svg width="36" height="36" viewBox="0 0 36 36" aria-hidden="true">
        <rect width="36" height="36" rx="8" fill="var(--sun)"></rect>
        <text
          x="18"
          y="24"
          text-anchor="middle"
          font-family="Archivo, sans-serif"
          font-weight="800"
          font-size="18"
          fill="var(--ink)">R</text
        >
      </svg>
      <span class="wordmark-text">Aussies R Us</span>
    </a>

    <details class="nav-mobile">
      <summary class="nav-toggle" aria-label="Menu">
        <span class="hamburger" aria-hidden="true">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </span>
      </summary>
      <nav class="nav-panel" aria-label="Primary">
        <ul class="nav-panel-list">
          {
            NAV.map((item) => (
              <li>
                <a class:list={['panel-link', { active: isActive(item.href) }]} href={item.href}>
                  {item.label}
                </a>
                {'children' in item && item.children && (
                  <ul class="panel-children">
                    {item.children.map((child) => (
                      <li>
                        <a
                          class:list={['panel-child', { active: path === child.href }]}
                          href={child.href}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))
          }
        </ul>
      </nav>
    </details>

    <nav class="nav-desktop" aria-label="Primary">
      <ul class="nav-list">
        {
          NAV.map((item) => (
            <li class:list={['nav-item', { 'has-children': 'children' in item && item.children }]}>
              {'children' in item && item.children ? (
                <details class="nav-disclosure">
                  <summary class:list={['nav-link', { active: isActive(item.href) }]}>
                    {item.label}
                    <span class="caret" aria-hidden="true">▾</span>
                  </summary>
                  <ul class="dropdown">
                    <li>
                      <a
                        class:list={['dropdown-link', { active: path === item.href }]}
                        href={item.href}
                      >
                        {item.label}
                      </a>
                    </li>
                    {item.children.map((child) => (
                      <li>
                        <a
                          class:list={['dropdown-link', { active: path === child.href }]}
                          href={child.href}
                        >
                          {child.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a class:list={['nav-link', { active: isActive(item.href) }]} href={item.href}>
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  function closeAll(except?: HTMLDetailsElement) {
    document
      .querySelectorAll<HTMLDetailsElement>('.nav-disclosure[open], .nav-mobile[open]')
      .forEach((el) => {
        if (el !== except) el.open = false;
      });
  }

  document.querySelectorAll<HTMLDetailsElement>('.nav-disclosure, .nav-mobile').forEach((el) => {
    el.addEventListener('toggle', () => {
      if (el.open) closeAll(el);
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeAll();
  });

  document.addEventListener('click', (e) => {
    const t = e.target as Node | null;
    if (!t) return;
    const inside = (t as Element).closest?.('.nav-disclosure, .nav-mobile, .site-header');
    if (!inside) closeAll();
  });
</script>

<style>
  .site-header {
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s-4);
    min-height: 72px;
    padding-block: var(--s-3);
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--s-3);
    text-decoration: none;
    color: var(--ink);
    flex-shrink: 0;
  }

  .wordmark-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-stretch: semi-expanded;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .nav-mobile {
    display: none;
    position: relative;
  }

  .nav-toggle {
    list-style: none;
    cursor: pointer;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: var(--r-s);
    background: var(--paper);
    color: var(--ink);
  }

  .nav-toggle::-webkit-details-marker {
    display: none;
  }

  .hamburger {
    position: relative;
    width: 20px;
    height: 14px;
  }

  .hamburger .bar {
    position: absolute;
    left: 0;
    width: 100%;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition:
      top 0.2s ease,
      transform 0.2s ease,
      opacity 0.2s ease;
  }

  .hamburger .bar:nth-child(1) {
    top: 0;
  }

  .hamburger .bar:nth-child(2) {
    top: 6px;
  }

  .hamburger .bar:nth-child(3) {
    top: 12px;
  }

  .nav-mobile[open] .hamburger .bar:nth-child(1) {
    top: 6px;
    transform: rotate(45deg);
  }

  .nav-mobile[open] .hamburger .bar:nth-child(2) {
    opacity: 0;
  }

  .nav-mobile[open] .hamburger .bar:nth-child(3) {
    top: 6px;
    transform: rotate(-45deg);
  }

  .nav-panel {
    position: absolute;
    top: calc(100% + var(--s-2));
    right: 0;
    left: auto;
    width: min(calc(100vw - (var(--gutter) * 2)), 22rem);
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-m);
    padding: var(--s-3);
    z-index: 60;
    max-height: min(70vh, 32rem);
    overflow-y: auto;
  }

  .nav-panel-list,
  .panel-children {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .panel-link {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: var(--s-2) var(--s-3);
    color: var(--ink);
    text-decoration: none;
    font-weight: 700;
    border-radius: var(--r-s);
  }

  .panel-link.active,
  .panel-child.active {
    color: var(--eucalypt);
  }

  .panel-children {
    padding: 0 0 var(--s-3) var(--s-3);
    margin-bottom: var(--s-2);
    border-bottom: 1px solid var(--line);
  }

  .nav-panel-list > li:last-child .panel-children {
    border-bottom: none;
    margin-bottom: 0;
  }

  .panel-child {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: var(--s-2) var(--s-3);
    color: var(--ink);
    text-decoration: none;
    font-size: var(--t-meta);
    border-radius: var(--r-s);
  }

  .panel-link:hover,
  .panel-child:hover {
    background: var(--paper-dim);
  }

  .nav-list {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: var(--s-1);
    list-style: none;
    margin: 0;
    padding: 0;
    justify-content: flex-end;
  }

  .nav-item {
    position: relative;
    display: flex;
    align-items: center;
    margin: 0;
  }

  .nav-disclosure {
    display: flex;
    align-items: center;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: var(--s-1);
    min-height: 44px;
    padding: var(--s-2) var(--s-3);
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
    font-size: var(--t-meta);
    white-space: nowrap;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
    font-family: inherit;
    list-style: none;
  }

  .nav-disclosure > summary.nav-link {
    list-style: none;
  }

  .nav-disclosure > summary.nav-link::-webkit-details-marker {
    display: none;
  }

  .nav-link.active,
  .nav-link:hover {
    border-bottom-color: var(--sun);
  }

  .caret {
    font-size: 0.7em;
    opacity: 0.7;
  }

  .dropdown {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    min-width: 240px;
    margin: 0;
    padding: var(--s-2);
    list-style: none;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-s);
    z-index: 50;
  }

  .nav-disclosure[open] > .dropdown {
    display: block;
  }

  .dropdown-link {
    display: block;
    padding: var(--s-3);
    min-height: 44px;
    color: var(--ink);
    text-decoration: none;
    border-radius: var(--r-s);
    font-size: var(--t-meta);
  }

  .dropdown-link:hover,
  .dropdown-link.active {
    background: var(--paper-dim);
    color: var(--eucalypt);
  }

  @media (max-width: 900px) {
    .nav-desktop {
      display: none;
    }

    .nav-mobile {
      display: block;
    }
  }

  @media (min-width: 901px) {
    .nav-mobile {
      display: none;
    }
  }
</style>
